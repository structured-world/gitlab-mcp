{
  "name": "gitlab-mcp-monorepo",
  "version": "9.0.2",
  "private": true,
  "description": "Monorepo root for @structured-world/gitlab-mcp and its optional packages",
  "packageManager": "yarn@4.13.0",
  "workspaces": [
    "packages/*"
  ],
  "resolutions": {
    "lodash": "4.17.23",
    "lodash-es": "4.17.23",
    "@hono/node-server": "1.19.14",
    "diff": "4.0.4",
